generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Release {
  id              String           @id @default(cuid())
  title           String?
  primaryArtist   String?
  artists         String[]         @default([])
  releaseDate     DateTime?
  status          String           @default("planned")
  platformLinks   Json
  coverArt        String?
  type            String?          @default("single")
  notes           String?
  label           String?
  upc             String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  splitAgreements SplitAgreement[]
  statementLines  StatementLine[]

  @@map("releases")
}

model Collaborator {
  id             String               @id @default(cuid())
  name           String?
  email          String?              @unique
  role           String?
  payeeReference String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  payouts        Payout[]
  agreements     SplitAgreement[]
  splits         StatementLineSplit[]

  @@map("collaborators")
}

model RoyaltyStatement {
  id            String               @id @default(cuid())
  provider      String
  reference     String?
  periodLabel   String?
  periodStart   DateTime?
  periodEnd     DateTime?
  statementDate DateTime?
  currency      String
  totalAmount   Float                @default(0)
  totalUnits    Float                @default(0)
  metadata      Json
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  batches       RoyaltyImportBatch[]
  lines         StatementLine[]

  @@map("royalty_statements")
}

model StatementLine {
  id           String               @id @default(cuid())
  statementId  String
  releaseId    String?
  sequence     Int?
  trackTitle   String?
  isrc         String?
  usageDate    DateTime?
  service      String?
  territory    String?
  units        Float                @default(0)
  netRevenue   Float                @default(0)
  grossRevenue Float?
  fee          Float?
  currency     String
  payoutStatus String               @default("pending")
  metadata     Json
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  payableItems PayableItem[]
  splits       StatementLineSplit[]
  release      Release?             @relation(fields: [releaseId], references: [id])
  statement    RoyaltyStatement     @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@map("statement_lines")
}

model StatementLineSplit {
  id              String        @id @default(cuid())
  statementLineId String
  collaboratorId  String?
  sharePercentage Float?
  amount          Float?
  payoutStatus    String        @default("pending")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payableItems    PayableItem[]
  collaborator    Collaborator? @relation(fields: [collaboratorId], references: [id])
  statementLine   StatementLine @relation(fields: [statementLineId], references: [id], onDelete: Cascade)

  @@map("statement_line_splits")
}

model SplitAgreement {
  id              String       @id @default(cuid())
  releaseId       String
  collaboratorId  String
  sharePercentage Float?
  agreementType   String?
  effectiveDate   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now())
  collaborator    Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  release         Release      @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, collaboratorId])
  @@map("split_agreements")
}

model RoyaltyImportBatch {
  id                String           @id @default(cuid())
  statementId       String
  source            String
  importedAt        DateTime         @default(now())
  importedBy        String?
  originalFilename  String?
  lineItemCount     Int
  releaseCount      Int
  collaboratorCount Int
  totalRevenue      Float            @default(0)
  currency          String
  status            String           @default("completed")
  warnings          Json
  errors            Json
  statement         RoyaltyStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@map("royalty_import_batches")
}

model PayoutBatch {
  id               String    @id @default(cuid())
  status           String    @default("pending")
  processor        String?
  processorBatchId String?
  requestedBy      String?
  requestedAt      DateTime  @default(now())
  processedAt      DateTime?
  totalAmount      Float     @default(0)
  currency         String    @default("USD")
  payoutCount      Int       @default(0)
  metadata         Json
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  payouts          Payout[]

  @@map("payout_batches")
}

model Payout {
  id             String           @id @default(cuid())
  batchId        String
  collaboratorId String
  amount         Float
  currency       String           @default("USD")
  status         String           @default("pending")
  externalId     String?
  failureReason  String?
  retryCount     Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  payableItems   PayableItem[]
  auditLogs      PayoutAuditLog[]
  batch          PayoutBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  collaborator   Collaborator     @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)

  @@map("payouts")
}

model PayableItem {
  id                   String              @id @default(cuid())
  payoutId             String
  statementLineId      String
  statementLineSplitId String?
  amount               Float
  sharePercentage      Float?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @default(now())
  payout               Payout              @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  statementLine        StatementLine       @relation(fields: [statementLineId], references: [id], onDelete: Cascade)
  statementLineSplit   StatementLineSplit? @relation(fields: [statementLineSplitId], references: [id])

  @@map("payable_items")
}

model PayoutAuditLog {
  id        String   @id @default(cuid())
  payoutId  String
  eventType String
  message   String?
  detail    Json
  createdAt DateTime @default(now())
  payout    Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@map("payout_audit_logs")
}
